+    btn.addEventListener('click', () => {
+      const val = btn.dataset.val;
+      if (val === 'auto') {
+        if (!lastFollowWindows) execCommand('toggleThemeFollowWindows');
+        // Si Windows es oscuro y el doc no está invertido, invertirlo. Y viceversa.
+        if (lastWindowsDark && !lastDocInverted) execCommand('toggleDocumentInvert');
+        if (!lastWindowsDark && lastDocInverted) execCommand('toggleDocumentInvert');
+      } else if (val === 'light') {
+        if (lastFollowWindows) execCommand('toggleThemeFollowWindows');
+        if (lastAppDark) execCommand('toggleTheme');
+        // En modo claro, asegurar que el documento NO esté invertido
+        if (lastDocInverted) execCommand('toggleDocumentInvert');
+      } else if (val === 'dark') {
+        if (lastFollowWindows) execCommand('toggleThemeFollowWindows');
+        if (!lastAppDark) execCommand('toggleTheme');
+        // En modo oscuro, asegurar que el documento SÍ esté invertido
+        if (!lastDocInverted) execCommand('toggleDocumentInvert');
+      }
+    });
+  });
+}
+
+const diToggle=document.getElementById('documentInvertToggle');
+if(diToggle) diToggle.addEventListener('click', () => execCommand('toggleDocumentInvert'));
+post('toolbarReady', {});
+
+let isRevealed = false;
+function revealToolbar() {
+  if (isRevealed) return;
+  isRevealed = true;
+  const skel = document.getElementById('skeletonToolbar');
+  const tool = document.getElementById('mainToolbar');
+  if (skel) skel.style.setProperty('display', 'none', 'important');
+  if (tool) tool.style.setProperty('display', 'flex', 'important');
+}
+setTimeout(revealToolbar, 800);
+if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
+  revealToolbar();
+}
+</script>
+</body>
+</html>
