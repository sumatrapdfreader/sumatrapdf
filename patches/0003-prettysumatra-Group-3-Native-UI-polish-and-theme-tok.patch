+static COLORREF LerpColor(COLORREF a, COLORREF b, int t256) {
+    int ar = GetRValue(a);
+    int ag = GetGValue(a);
+    int ab = GetBValue(a);
+    int br = GetRValue(b);
+    int bg = GetGValue(b);
+    int bb = GetBValue(b);
+    int r = ar + ((br - ar) * t256) / 256;
+    int g = ag + ((bg - ag) * t256) / 256;
+    int bl = ab + ((bb - ab) * t256) / 256;
+    return RGB(r, g, bl);
+}
