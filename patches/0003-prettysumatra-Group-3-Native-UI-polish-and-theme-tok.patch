+static bool IsToolbarLightColor(COLORREF c) {
+    int r = GetRValue(c);
+    int g = GetGValue(c);
+    int b = GetBValue(c);
+    // ITU-R BT.709 luma approximation
+    int luma = (2126 * r + 7152 * g + 722 * b) / 10000;
+    return luma >= 160;
+}
