+static RECT ToToolbarClientRect(HWND hwndToolbar, HWND child) {
+    RECT r{};
+    if (!child || !GetWindowRect(child, &r)) {
+        return {0, 0, 0, 0};
+    }
+    MapWindowPoints(HWND_DESKTOP, hwndToolbar, (LPPOINT)&r, 2);
+    return r;
+}
