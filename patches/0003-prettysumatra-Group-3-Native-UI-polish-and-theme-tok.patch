+static bool GetToolbarContentRect(HWND hwndToolbar, RECT& outRect) {
+    int nButtons = (int)SendMessageW(hwndToolbar, TB_BUTTONCOUNT, 0, 0);
+    if (nButtons <= 0) {
+        return false;
