{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-rel-64",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/d",
                "/c",
                "scripts\\build-vs2022.cmd Release x64 SumatraPDF-dll"
            ],
            "group": "build",
            "presentation": {
                // Reveal the output only if unrecognized errors occur.
                "reveal": "silent"
            },
            // Use the standard MS compiler pattern to detect errors, warnings and infos
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-rel-asan-64",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/d",
                "/c",
                "scripts\\build-vs2022.cmd Release x64_asan SumatraPDF"
            ],
            "group": "build",
            "presentation": {
                // Reveal the output only if unrecognized errors occur.
                "reveal": "silent"
            },
            // Use the standard MS compiler pattern to detect errors, warnings and infos
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-dbg-64",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/d",
                "/c",
                "scripts\\build-vs2022.cmd Debug x64 SumatraPDF-dll"
            ],
            "group": "build",
            "presentation": {
                // Reveal the output only if unrecognized errors occur.
                "reveal": "silent"
            },
            // Use the standard MS compiler pattern to detect errors, warnings and infos
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run-dbg-64",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$exe='${workspaceFolder}\\out\\dbg64\\SumatraPDF.exe'; if (Test-Path $exe) { & $exe } else { Write-Error \"No existe: $exe\"; exit 1 }"
            ],
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        },
        {
            "label": "run-rel-64",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$exe='${workspaceFolder}\\out\\rel64\\SumatraPDF.exe'; if (Test-Path $exe) { & $exe } else { Write-Error \"No existe: $exe\"; exit 1 }"
            ],
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        },
        {
            "label": "build-and-run-dbg-64",
            "dependsOrder": "sequence",
            "dependsOn": [
                "build-dbg-64",
                "run-dbg-64"
            ],
            "problemMatcher": []
        },
        {
            "label": "build-and-run-rel-64",
            "dependsOrder": "sequence",
            "dependsOn": [
                "build-rel-64",
                "run-rel-64"
            ],
            "problemMatcher": []
        }
    ]
}

// 	
